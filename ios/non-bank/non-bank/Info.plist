<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <!--
        Home-screen / user-facing app name. Kept separate from CFBundleName
        ($(PRODUCT_NAME) = "non-bank", the internal target/bundle identity)
        so the displayed name reads "Non Bank" without renaming the target,
        bundle id, scheme, or product — none of which need to change.
    -->
    <key>CFBundleDisplayName</key>
    <string>Non Bank</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <!--
        Export-compliance: the app uses only exempt encryption — HTTPS/TLS
        to the backend and Apple's App Attest (Secure Enclave) — no
        proprietary crypto ships in the binary. Declaring NO here skips the
        encryption question on every TestFlight / App Store upload.
    -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!--
        UIMainStoryboardFile / UILaunchStoryboardName were leftovers from
        the old UIKit project template. This is a SwiftUI `@main` app —
        no storyboards exist. Keeping these keys made UIKit search for a
        non-existent `Main.storyboard` and crash with NSInvalidArgumentException.
        Launch screen is auto-generated via `INFOPLIST_KEY_UILaunchScreen_Generation`.
    -->
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Used to import and export your transaction files on this device.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Used to choose a receipt photo from your library so its items can be scanned.</string>
    <key>NSCameraUsageDescription</key>
    <string>Used to scan receipts with the camera so their items can be recognized automatically.</string>
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>
    <!--
        Custom URL scheme used as the *interim* deep-link mechanism for share
        links (e.g. `nonbank://share?p=BASE64URL`). When a Universal Link
        domain is set up later, both schemes will work — `nonbank://` keeps
        functioning as a fallback for development and for App Store-deferred
        installs where the receiver hasn't yet associated the universal
        domain.
    -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.nonbank.share</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>nonbank</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
