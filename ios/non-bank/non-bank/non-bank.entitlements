<?xml version="1.0" encoding="UTF-8"?>
<!--
	CloudKit is ENABLED (paid Apple Developer Program membership active).

	To finish wiring in Xcode (one-time):
	  Signing & Capabilities → + Capability → iCloud → check CloudKit →
	  select/create the container `iCloud.$(PRODUCT_BUNDLE_IDENTIFIER)`.
	  Xcode registers the capability on the App ID + provisioning profile;
	  it reconciles the keys below.

	Still commented out — enable when you choose to:
	  - `aps-environment` / Push Notifications: only needed for REAL-TIME
	    sync (a remote-notification handler consuming the CloudKit
	    subscription). v1 uses foreground sync, so it's optional.
	  - `com.apple.developer.associated-domains` (Universal Links): the
	    share flow uses the custom `nonbank://` scheme + the `non-bank.app`
	    web fallback today. To switch to Universal Links later, add the
	    associated domain for `non-bank.app` (NOT the old github.io host)
	    AND flip `SharedTransactionLink.defaultURLStyle` to `.universalLink`.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>

	<!--
		<key>aps-environment</key>
		<string>development</string>

		<key>com.apple.developer.associated-domains</key>
		<array>
			<string>applinks:non-bank.app</string>
		</array>
	-->
</dict>
</plist>
