<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No cross-app / cross-developer tracking: no IDFA, no AdSupport,
	     no AppTrackingTransparency prompt. Analytics is first-party only. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- What the app collects. Receipt images are sent to the parsing
	     backend transiently (parsed, then discarded — never retained), so
	     under Apple's definition they are NOT "collected" and aren't listed.
	     Transactions live on-device + the user's own iCloud, not on our
	     servers. The only retained off-device data is first-party analytics
	     (Firebase Analytics / GA4). Firebase's own bundled manifest covers
	     the SDK's collection; these entries state it at the app level too. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>
	</array>

	<!-- Required Reason APIs called by OUR binary. Third-party SDKs
	     (Firebase) ship their own manifests, so only the app's direct use
	     is listed here. The app reads/writes its own UserDefaults (settings,
	     preferences) across ~19 files → CA92.1. File-timestamp, system-boot-
	     time and disk-space APIs are not used by our code, so they're omitted. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
